/* 
   Arquivo CSS Final - Tô Legal SP
   Foco: Garantir o fundo cinza na barra superior e alinhamento perfeito
*/

/* --- RESET E BASE --- */
* { box-sizing: border-box; margin: 0; padding: 0; }
body { overflow-x: hidden; width: 100%; font-family: 'Roboto', sans-serif; background: #fff; }

/* --- BARRA CINZA SUPERIOR (TOP BAR) --- */
/* Esta é a classe que criamos no HTML */
.top-bar-fix {
    background-color: #333333 !important; /* Cinza escuro */
    width: 100% !important;
    display: block !important;
    position: relative !important;
    z-index: 9999 !important;
}

.top-bar-fix .e-con-inner {
    max-width: 1200px !important;
    margin: 0 auto !important;
    display: flex !important;
    flex-direction: row !important;
    justify-content: space-between !important;
    align-items: center !important;
    padding: 10px 15px !important;
    background: transparent !important; /* Garante que o fundo do container não tape o cinza */
}

/* Estilo dos links na barra cinza */
.top-bar-fix a, .top-bar-fix p, .top-bar-fix div {
    color: #ffffff !important;
    font-size: 12px !important;
    text-decoration: none !important;
    white-space: nowrap !important;
    background: transparent !important;
}

.top-bar-fix .e-con-child {
    background: transparent !important;
    display: flex !important;
    align-items: center !important;
}

/* --- CABEÇALHO PRINCIPAL (LOGOS) --- */
.main-header-container {
    background: #ffffff !important;
    width: 100% !important;
}

.main-header-container .e-con-inner {
    max-width: 1200px !important;
    margin: 0 auto !important;
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    padding: 20px 15px !important;
}

img { max-width: 100%; height: auto; display: block; }

/* Tamanhos das Logos */
img[alt="Logo Principal"], img[alt="logoPrincipal"] { width: 200px !important; }
img[alt="lgo_prefeitura"] { width: 160px !important; }

/* --- RESPONSIVIDADE MOBILE --- */
@media (max-width: 767px) {
    /* Barra Cinza no Mobile */
    .top-bar-fix .e-con-inner {
        flex-direction: column !important;
        gap: 12px !important;
        padding: 15px !important;
    }
    
    .top-bar-fix .e-con-child {
        width: 100% !important;
        justify-content: center !important;
    }

    /* Header Principal no Mobile */
    .main-header-container .e-con-inner {
        flex-direction: column !important;
        gap: 20px !important;
    }

    /* Logos no Mobile */
    img[alt="Logo Principal"], img[alt="logoPrincipal"] { width: 150px !important; }
    img[alt="lgo_prefeitura"] { width: 130px !important; }
}
